{
  "name": "cube-segments-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch --env-file=../.env --env-file=../.env.local src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "snapshot": "tsx src/scripts/write-snapshot.ts",
    "check:metric-drift": "tsx --env-file=../.env --env-file=../.env.local src/scripts/check-metric-drift.ts",
    "audit:metric-trust": "tsx --env-file=../.env --env-file=../.env.local src/scripts/audit-and-promote-metric-trust.ts",
    "migrate:lakehouse-local": "tsx --env-file=../.env --env-file=../.env.local src/scripts/migrate-lakehouse-schema-to-local.ts",
    "load:game-test-data": "tsx --env-file=../.env --env-file=../.env.local src/scripts/load-game-test-data-range.ts",
    "relocate:test-data": "tsx --env-file=../.env --env-file=../.env.local src/scripts/relocate-test-data-into-khoitn-schema.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "@fastify/cors": "^9.0.1",
    "better-sqlite3": "^12.10.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^5.1.0",
    "gds-cube": "file:..",
    "jose": "^6.2.3",
    "js-yaml": "^4.1.0",
    "mysql2": "^3.22.5",
    "uuid": "^9.0.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.16.2",
    "typescript": "~5.2.2",
    "vitest": "^2.1.3"
  }
}
