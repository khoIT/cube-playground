#!/usr/bin/env bash
# Refreshes the segments + chat seed snapshots from the local SQLite DBs
# before every push. Fails the push if either snapshot drifts — author must
# then `git add` + commit the refreshed file and push again.
#
# Skips a snapshot silently when its local DB or its package's node_modules
# is missing (fresh clones / contributors who don't run that service). The
# whole hook is safe to keep enabled everywhere.

set -eu

ROOT="$(git rev-parse --show-toplevel)"

# (db_path, node_modules_path, npm_prefix, snapshot_path, label) tuples.
# Each row drives one snapshot+drift cycle below.
TARGETS=(
  "$ROOT/server/data/segments.db|$ROOT/server/node_modules|$ROOT/server|$ROOT/server/data/seed/segments-snapshot.json|segments"
  "$ROOT/chat-service/runtime/chat.db|$ROOT/chat-service/node_modules|$ROOT/chat-service|$ROOT/chat-service/runtime/seed/chat-snapshot.json|chat"
)

DRIFTED=()
DRIFTED_PATHS=()

for entry in "${TARGETS[@]}"; do
  IFS='|' read -r db nm prefix snapshot label <<<"$entry"

  [ -f "$db" ] || continue
  [ -d "$nm" ] || continue

  npm --prefix "$prefix" run --silent snapshot >/dev/null

  if ! git diff --quiet -- "$snapshot"; then
    DRIFTED+=("$label")
    DRIFTED_PATHS+=("$snapshot")
  fi
done

if [ ${#DRIFTED[@]} -eq 0 ]; then
  exit 0
fi

echo
echo "[pre-push] seed snapshot(s) out of date — local DB has newer state than"
echo "           the committed seed file(s). Refreshed for you:"
echo
for p in "${DRIFTED_PATHS[@]}"; do
  echo "             $p"
done
echo
echo "           Commit and push again:"
echo
echo "             git add ${DRIFTED_PATHS[*]}"
echo "             git commit -m \"chore(seed): refresh ${DRIFTED[*]} snapshot\""
echo "             git push"
echo
echo "           To skip this hook for a single push: git push --no-verify"
echo
exit 1
