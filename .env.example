VITE_CUBE_API_URL=http://localhost:4000/cubejs-api/v1
VITE_CUBE_TOKEN=

# dev-only, server-side; resolves to your local Cube schema root (not exposed to the browser)
VITE_CUBE_MODEL_DIR=../cube/model

# =============================================================================
# Per-game Cube JWTs (server-side; unprefixed — not exposed to the browser)
#
# When CUBEJS_API_SECRET is set, the playground server mints a fresh HS256 JWT
# on every game switch: { game: <gds.config.json id>, userId: <below> }.
# The token is delivered by GET /api/playground/cube-token?game=<id> and the
# frontend pushes it into SecurityContext, so /meta and /load fire against the
# correct tenant's yaml. Leave blank to keep using the single VITE_CUBE_TOKEN
# (no per-game routing).
#
# Must match CUBEJS_API_SECRET on the Cube cluster (cube-dev/.env).
# CUBE_PLAYGROUND_USER_ID must exist in cube-dev's auth-users.json with
# allowedGames covering every id in gds.config.json. The example file ships a
# `playground` user with cross-game admin access.
# =============================================================================
CUBEJS_API_SECRET=
CUBE_PLAYGROUND_USER_ID=playground

# =============================================================================
# Onboarding agent — Trino profiler connector (server-side only; unprefixed)
#
# A *connector* is a warehouse connection profile used by the onboarding agent
# to introspect + profile a raw Trino schema (catalog `game_integration`).
# This knowingly relaxes the credential-free design and is isolated in the
# trino-profiler service. Leave TRINO_PROFILER_HOST blank to keep the profiler
# DISABLED (the Data hub then shows a "not configured" state). Add more
# connectors via an optional `connectors.config.json` (CONNECTORS_CONFIG_PATH).
# =============================================================================
TRINO_PROFILER_HOST=
TRINO_PROFILER_PORT=443
TRINO_PROFILER_USER=playground
TRINO_PROFILER_PASS=
TRINO_PROFILER_CATALOG=game_integration
TRINO_PROFILER_SSL=true
TRINO_PROFILER_WORKSPACE=local

# Connector secret vault — encrypts credentials for connectors provisioned from
# the Data product UI (real self-serve connect, beyond the env-seeded Trino one).
# 32-byte key, base64 (44 chars) or hex (64 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Leave blank to disable DB-backed connectors; the env-seeded TRINO_PROFILER_*
# bootstrap connector still works without it.
CONNECTOR_SECRET_KEY=

# LiteLLM gateway (server-side only — keep unprefixed so secrets stay out of the browser bundle)
LITELLM_BASE_URL=https://aawp-litellm-testing.vnggames.net
LITELLM_API_KEY_DEV=
LITELLM_API_KEY_STG=
LITELLM_MODEL=claude-sonnet-4-6

# Chat agent microservice (chat-service/) — used by /api/chat/* proxy in server/
# In LOCAL DEV these (and the ANTHROPIC_* below) live in chat-service/.env, which
# the chat process loads via dotenv. In the PROD container they come from the
# single shared .env injected by compose (see docs/deployment-guide.md →
# Containerized deploy). CHAT_SERVICE_URL is dev-only topology; in compose the
# server reaches chat at http://chat-service:3005.
CHAT_SERVICE_URL=http://localhost:3005
CHAT_FEATURE_ENABLED=true

# Chat-service LLM gateway — REQUIRED whenever chat runs (the chat-service exits
# at boot if either is missing). Point ANTHROPIC_BASE_URL at the LiteLLM gateway
# and ANTHROPIC_API_KEY at its key. CUBE_API_URL is the cube cluster the chat
# agent queries.
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
CUBE_API_URL=http://localhost:4000

# Langfuse Cloud: when set, /dev/chat-audit shows an "Open in Langfuse" deep-link per turn.
# Format: https://cloud.langfuse.com  (no trailing slash). Leave unset to hide the button.
# VITE_LANGFUSE_HOST=https://cloud.langfuse.com

# Shared service token used by chat-service when calling main-server internal
# endpoints (e.g. POST /api/segments/:id/refresh from the saved-segment
# refresh handler in phase-12). Set the same value on both processes. Leave
# unset in dev if chat-service does not call back into main-server.
MAIN_SERVER_SERVICE_TOKEN=

# Internal bridge secret for main-server → chat-service calls (segment AI
# brief, activity-telemetry stats, cost, llm-auth). Server sends it as
# x-internal-secret; chat-service validates. Fails closed: missing/mismatched
# value → AI brief generation 502s and /internal/* bridges 403/503. REQUIRED
# in prod (see docs/deployment-guide.md). Generate: openssl rand -hex 32
INTERNAL_SECRET=

# =============================================================================
# Phase 6 — Keycloak SSO + app JWT (RBAC)
#
# Local dev: `docker compose up -d keycloak` boots a KC 26 container on
# http://localhost:18080 with the realm in keycloak/realm-export.json
# (realm=cube-playground, client=cube-playground-web, viewer/editor/admin
# roles, three test users: admin/admin123, editor/editor123, viewer/viewer123).
#
# Auth flow: FE redirects to KEYCLOAK_URL/realms/$REALM/protocol/openid-connect/auth
# → KC bounces back to http://localhost:3000/auth/callback?code=… → FE POSTs
# the code to /api/auth/keycloak/callback → server exchanges code → mints its
# OWN HS256 app JWT (JWT_SECRET below) → FE stores app JWT in localStorage.
# Every subsequent request carries `Authorization: Bearer <app-jwt>`; the
# server's `authenticate` preHandler resolves req.user from it.
#
# Set AUTH_DISABLED=true for friction-free local dev — the server synthesizes
# req.user={id:'dev',role:'admin',allowedGames:[<all>]} and the FE skips the
# Keycloak redirect. Keep AUTH_DISABLED unset (or false) to exercise the real
# flow once KC is running.
# =============================================================================
AUTH_DISABLED=true
KEYCLOAK_URL=http://localhost:18080
KEYCLOAK_REALM=cube-playground
KEYCLOAK_CLIENT_ID=cube-playground-web
# Optional — only for confidential clients. Our default realm uses a public
# client (no secret). Leave unset for local dev.
KEYCLOAK_CLIENT_SECRET=
# 32+ random chars. Used to sign + verify the app JWT. Rotating invalidates
# all issued app JWTs (forces every user back through KC).
JWT_SECRET=local-dev-app-jwt-secret-change-me-32-chars-min
JWT_EXPIRES_MINUTES=720

# Comma-separated emails seeded as `active` admins on every boot. **Set before
# the first prod deploy** or no one can reach /admin/access (lockout). Dev with
# AUTH_DISABLED=true does not need it.
AUTH_BOOTSTRAP_ADMINS=

# Shared secret guarding GET /internal/access/:key (cube-dev calls it for
# per-user game authz). MUST equal cube-dev's AUTH_INTERNAL_SECRET. Required in
# prod; unset in dev when cube-dev reads the local JSON fallback.
CUBE_AUTH_INTERNAL_SECRET=

# Optional bootstrap admin override for the KC container (matches
# docker-compose.yml). Leave unset to use the defaults (admin/admin).
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin
KC_PORT=18080
