# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
dist/
bin/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# package manager
# package-lock.json is committed — Docker build runs `npm ci`, which requires it
yarn.lock
pnpm-lock.yaml

# semantic-release
.nyc_output

# env files (can opt-in for committing if needed)
.env*
!.env.example
# Local prod-mirror stack template is a safe, secret-free template — commit it.
# The real .env.docker.local (filled with creds) stays ignored by the .env* rule.
!.env.docker.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# flutter
.dart_tool
build
GoogleService-Info.plist

repomix-output.xml
server/data/*
!server/data/seed/
server/dist/
server/node_modules/
chat-service/runtime/*
!chat-service/runtime/seed/
chat-service/dist/
chat-service/node_modules/
.serena/cache
!plans/templates/*
screenshots/*
docs/screenshots/*
logs.txt
test-ck
__pycache__

# CK meta commands
prompt.md
ck.md

# Generated runtime layout for release/install smoke tests
/.claude/
# But track repo-level rules that Claude Code reads
!/.claude/rules/

# Local-only state inside tracked claude source
claude/agent-memory/
claude/hooks/.logs/
claude/session-state/latest.md
claude/session-state/archive/
claude/settings.bak.json
claude/skills/ai-multimodal/assets/demo-*.claude/session-state/*.tmp

# Gemini CLI settings (symlink to staged .claude/.mcp.json)
.gemini/settings.json
# Showoff/marketing assets (images, showcases)
assets/
# Exception: use-mcp ships a persistent tool catalog at assets/tools.json
!claude/skills/use-mcp/assets/
!claude/skills/use-mcp/assets/**
# Exception: app-source assets (logos, brand imports) must be tracked
!src/assets/
!src/assets/**

# External repos for study/reference
external/

# Git worktrees (local development only)
worktrees/

# Schema-write audit log — may contain raw YAML payloads; not for git history.
_audit.jsonl

# Playwright artifacts
test-results/
playwright-report/

# Dev server logs — rolling capture of `npm run dev:all` (may contain raw
# payloads/tokens). Keep the folder + policy README, ignore the log files.
logs/*.log

# Vendored Cube semantic layer (de-submoduled from metrics-catalogue).
# Only cube-dev/cube/ (config + models) is mounted into the in-stack cube_api
# container (docker-compose.prod.yml) and must ship with the deploy push.
# Everything else from the source repo (README, examples, plans, release
# manifest, .env.example) is local-reference only — keep it out of git history.
# To refresh models: re-vendor cube-dev/cube/ from the source repo and redeploy.
/cube-dev/*
!/cube-dev/cube/
