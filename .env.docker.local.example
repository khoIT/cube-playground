# =============================================================================
# .env.docker.local — env for the LOCAL prod-mirror Docker stack (`npm run stack`).
#
# This is the laptop counterpart of the Vault-written prod `.env`. The container
# model merges every service's secrets into ONE flat file; `docker-compose.local.yml`
# points each Node service's `env_file` here and the wrapper feeds it to compose
# for `${VAR}` interpolation too. Copy to `.env.docker.local` and fill in:
#
#   cp .env.docker.local.example .env.docker.local
#
# It is gitignored + dockerignored (the `.env.*` rule) — secrets never leave the
# host or get baked into an image. Topology (PORT, DB_PATH, service URLs, the
# WORKSPACES path) stays in compose, NOT here — see docker-compose.prod.yml.
# =============================================================================

# --- Posture -----------------------------------------------------------------
# true = the local-dev posture: synth admin, SSO wall down, and the in-stack
# `local` Cube workspace opens to all games with no login/grants. Mirrors how a
# developer runs dev:all. Flip to false only to exercise the real Keycloak +
# DB-default-deny flow against a local KC (`docker compose up -d keycloak`).
AUTH_DISABLED=true

# App-JWT signing (≥16 chars). Any stable local string is fine.
JWT_SECRET=local-dev-app-jwt-secret-change-me-32-chars-min
JWT_EXPIRES_MINUTES=720

# --- In-stack Cube (the `local` workspace: server ⇄ cube_api:4000) -----------
# CUBEJS_API_SECRET is shared: the server mints the per-game JWT, cube_api
# verifies it — the two MUST be identical (compose injects this same file into
# both, so one value here covers both).
CUBEJS_API_SECRET=local-dev-cube-shared-secret
CUBE_PLAYGROUND_USER_ID=playground

# Shared secret guarding the server's /internal/access/:key endpoint that
# cube_api's auth-db.js calls to resolve per-user game grants. With
# AUTH_DISABLED=true the server returns an all-games admin regardless, so any
# value works locally; keep it set so the bridge is wired like prod.
CUBE_AUTH_INTERNAL_SECRET=local-dev-internal-secret

# Trino creds for cube_api. /meta + browsing + game switching work WITHOUT these
# (AUTH_DISABLED). Fill them in only to run real data queries (copy from your
# cube-dev/.env). gio-gds-trino is TLS-only → keep SSL=true.
CUBEJS_DB_HOST=
CUBEJS_DB_PORT=8080
CUBEJS_DB_USER=
CUBEJS_DB_PASS=
CUBEJS_DB_PRESTO_CATALOG=game_integration
CUBEJS_DB_CATALOG=game_integration
CUBEJS_DB_SSL=true

# Cube Store image tag. On Apple Silicon the wrapper auto-sets the arm64v8 tag
# (cubejs/cubestore is NOT multi-arch); on amd64 it leaves compose's :latest.
# Uncomment to pin explicitly:
# CUBESTORE_TAG=v1.6.46-arm64v8

# --- Chat-service (boots ONLY if both ANTHROPIC_* are set) -------------------
CHAT_FEATURE_ENABLED=true
# Point at the LiteLLM gateway + its key. Leave blank to skip chat (the service
# exits at boot without them; the rest of the stack still comes up since the
# server depends_on chat with condition: service_started, not healthy).
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=

# Optional server-side LLM features (catalog assist, scaffolding).
LITELLM_BASE_URL=https://aawp-litellm-testing.vnggames.net
LITELLM_API_KEY_STG=
LITELLM_MODEL=claude-sonnet-4-6

# Optional: chat↔server callback auth (same value both sides — one file here).
MAIN_SERVER_SERVICE_TOKEN=

# --- Onboarding profiler + DB connectors (optional) --------------------------
CONNECTOR_SECRET_KEY=
TRINO_PROFILER_HOST=
TRINO_PROFILER_PORT=443
TRINO_PROFILER_USER=playground
TRINO_PROFILER_PASS=
TRINO_PROFILER_CATALOG=game_integration
TRINO_PROFILER_SSL=true
TRINO_PROFILER_WORKSPACE=local

# --- Published port (compose interpolation) ----------------------------------
# The nginx `web` container serves the whole mirrored stack here.
PUBLIC_PORT=11000
# Cube Playground UI + SQL API (published by cube_api, same as prod compose).
CUBE_PUBLIC_PORT=17001
CUBE_SQL_PORT=15432
