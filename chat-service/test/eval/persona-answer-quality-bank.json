{
  "about": "Persona-grounded answer-quality bank for business-leader (GM/publishing) and liveops-manager questions. Distinct from resolver-smoketest-bank.json (a narrow resolver regression guard graded on exact member binding). Here cases are named for the DECISION they serve, and graded on an acceptable-member SET + answer-shape, never an exact ref — so the bank stays game-generic the same way the resolver fix did (members are byte-identical across games; only the resolved cube varies).",
  "schema": {
    "id": "stable case id, persona-prefixed (bl- = business leader, lo- = liveops)",
    "persona": "business-leader | liveops-manager",
    "intent": "decision category the question serves",
    "question": "the natural-language prompt fed to the chat turn",
    "curationGroup": "runner grouping key (reused by answer-quality-runner)",
    "dataClass": "shape = resolver + answer-shape correctness, gradable on the single-month synthetic corpus, runs every game in CI | analytics = needs real multi-period / payer-rich data, illustrative until a richer corpus exists",
    "acceptableMembers": "set of LEAF member names (cube-relative tail) any of which is a valid bind for this decision; empty = any valid metric (open-ended pulse). Generalises the parity-matrix 'platform-family leaf' trick.",
    "acceptableDims": "optional set of acceptable breakdown-dim leaf names; omit if no breakdown is required",
    "requiredGrain": "expected row grain when it matters (day | week | month | player | segment); omit if grain is free",
    "expectsDecline": "true when the right behaviour is to decline/disclose (coverage-honesty case) rather than emit an artifact",
    "rubric": "judge-dimension weights for the analytics lane (intent_fit, time_scoping, coverage_honesty, decision_framing, artifact_correctness); shape lane ignores these and grades structurally"
  },
