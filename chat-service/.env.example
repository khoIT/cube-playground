PORT=3005
LOG_LEVEL=info

# VNG LiteLLM proxy (copy from monet-v1.3-20260519/.env)
ANTHROPIC_BASE_URL=https://aawp-litellm-testing.vnggames.net
ANTHROPIC_API_KEY=
CHAT_MODEL=claude-sonnet-4-6
CHAT_MAX_OUTPUT_TOKENS=4096

# Upstream services
SERVER_BASE_URL=http://localhost:3004
CUBE_API_URL=http://localhost:4000

# Persistence
CHAT_DB_PATH=./runtime/chat.db
CHAT_MAX_TURNS_PER_SESSION=40
CHAT_MAX_TOKENS_PER_TURN=8000

# Skill loader — LRU TTL (ms). Default: 5000 dev / 60000 prod.
SKILL_LOADER_TTL_MS=5000

# Context + cost
CHAT_CONTEXT_BUDGET_TOKENS=180000
CHAT_TITLE_MODEL=claude-haiku-4-5-20251001
CHAT_COST_PER_1K_INPUT_USD=0.003
CHAT_COST_PER_1K_OUTPUT_USD=0.015

# Rate limiting
CHAT_RATE_LIMIT_PER_OWNER_PER_MIN=30

# Optional MCP exposure (off by default)
CHAT_MCP_ENABLED=false
