PORT=3005
LOG_LEVEL=info

# VNG LiteLLM proxy (copy from monet-v1.3-20260519/.env)
ANTHROPIC_BASE_URL=https://aawp-litellm-testing.vnggames.net
ANTHROPIC_API_KEY=
# Optional balance-exhaustion failover keys, tried in order primary → stg → backup
# when the active key reports "credit balance is too low" / budget exceeded.
ANTHROPIC_API_STG_KEY=
ANTHROPIC_API_BACKUP_KEY=
# Last-resort failover: Claude subscription OAuth token (run `claude setup-token`
# on a Pro/Max account, paste the sk-ant-oat-… token here). Used only after every
# gateway key drains; the SDK then talks directly to api.anthropic.com on the
# subscription quota (5-hour usage windows). Leave empty to disable.
ANTHROPIC_SUBSCRIPTION_OAUTH_TOKEN=
# Cooldown (ms) before a drained key is retried (auto-recover after top-up).
ANTHROPIC_KEY_RETRY_COOLDOWN_MS=600000
CHAT_MODEL=claude-sonnet-4-6
CHAT_MAX_OUTPUT_TOKENS=4096

# Upstream services
SERVER_BASE_URL=http://localhost:3004
CUBE_API_URL=http://localhost:4000

# Persistence
CHAT_DB_PATH=./runtime/chat.db
CHAT_MAX_TURNS_PER_SESSION=40
CHAT_MAX_TOKENS_PER_TURN=8000

# Skill loader — LRU TTL (ms). Default: 5000 dev / 60000 prod.
SKILL_LOADER_TTL_MS=5000

# Context + cost
CHAT_CONTEXT_BUDGET_TOKENS=180000
CHAT_TITLE_MODEL=claude-haiku-4-5-20251001
# AI segment brief one-shot model (keep sonnet — gateway key 403s other models)
CHAT_BRIEF_MODEL=claude-sonnet-4-6
CHAT_COST_PER_1K_INPUT_USD=0.003
CHAT_COST_PER_1K_OUTPUT_USD=0.015

# Rate limiting
CHAT_RATE_LIMIT_PER_OWNER_PER_MIN=30

# Optional MCP exposure (off by default)
CHAT_MCP_ENABLED=false

# Local dev only: rewrite legacy 'dev'-owned chat sessions to this owner at
# boot (matches the AUTH_DISABLED bootstrap-admin identity on the server).
# Leave unset on real-auth stacks — use scripts/reassign-session-owner.ts there.
DEV_OWNER_BACKFILL_TO=
