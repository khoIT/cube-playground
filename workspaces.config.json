{
  "_comment": "Cube workspace registry — server-side only. Client never sees URLs, only ids.",
  "default": "prod",
  "workspaces": [
    {
      "id": "local",
      "label": "Local dev",
      "cubeApiUrl": "http://localhost:4000",
      "authMode": "minted",
      "gameModel": "game_id"
    },
    {
      "id": "prod",
      "label": "Prod cube-dev (local mirror)",
      "cubeApiUrl": "http://localhost:16000",
      "authMode": "none",
      "gameModel": "prefix",
      "gamePrefixMap": {
        "cfm_vn": "cfm",
        "ballistar": "ballistar",
        "cros": "cros",
        "jus_vn": "jus"
      }
    }
  ]
}
